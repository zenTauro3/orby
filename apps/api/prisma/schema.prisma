generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum AgentType {
  SALES
  SUPPORT
  ONBOARDING
  CUSTOM
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  PENDING
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Company {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  plan      CompanyPlan @default(FREE)
  users     User[]
  agents    Agent[]
  invoices  Invoice[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(MEMBER)
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@map("users")
}

model Agent {
  id            String         @id @default(cuid())
  name          String
  description   String?
  type          AgentType      @default(SUPPORT)
  isActive      Boolean        @default(true)
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@map("agents")
}

model Invoice {
  id              String        @id @default(cuid())
  amount          Int
  currency        String        @default("EUR")
  status          InvoiceStatus @default(DRAFT)
  stripeInvoiceId String?       @unique
  dueDate         DateTime
  paidAt          DateTime?
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([companyId])
  @@map("invoices")
}

model Conversation {
  id         String             @id @default(cuid())
  externalId String?
  status     ConversationStatus @default(ACTIVE)
  agentId    String
  agent      Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages   Message[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}